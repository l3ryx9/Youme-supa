rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function onlyUpdates(allowedFields) {
      return request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(allowedFields);
    }

    function hasAcceptedRequestBetween(a, b) {
      return (exists(/databases/$(database)/documents/partnerRequests/$(a + '_' + b)) &&
              get(/databases/$(database)/documents/partnerRequests/$(a + '_' + b)).data.status == 'accepted') ||
             (exists(/databases/$(database)/documents/partnerRequests/$(b + '_' + a)) &&
              get(/databases/$(database)/documents/partnerRequests/$(b + '_' + a)).data.status == 'accepted');
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) &&
                       request.resource.data.id == userId &&
                       request.resource.data.email is string &&
                       request.resource.data.username is string &&
                       request.resource.data.username.size() >= 3 &&
                       request.resource.data.username.size() <= 20;
      allow update: if isOwner(userId) &&
                       onlyUpdates(['displayName', 'photoURL', 'bio',
                                    'isOnline', 'lastSeen', 'aiEnabled',
                                    'fcmToken', 'updatedAt', 'isEmailVerified']);
      allow delete: if isOwner(userId);
    }

    match /publicProfiles/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) &&
                       request.resource.data.keys().hasOnly(
                         ['username', 'displayName', 'photoURL', 'bio',
                          'isOnline', 'lastSeen', 'e2ePublicKey']
                       ) &&
                       request.resource.data.username is string;
      allow update: if isOwner(userId) &&
                       onlyUpdates(['displayName', 'photoURL', 'bio',
                                    'isOnline', 'lastSeen', 'e2ePublicKey']);
      allow delete: if isOwner(userId);
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if isAuthenticated() &&
                       request.resource.data.uid == request.auth.uid &&
                       request.resource.data.keys().hasOnly(['uid']);
      allow update: if false;
      allow delete: if isAuthenticated() &&
                       request.auth.uid == resource.data.uid;
    }

    match /conversations/{conversationId} {
      allow read: if isAuthenticated() &&
                     (resource == null ||
                      request.auth.uid in resource.data.participantIds);
      allow create: if isAuthenticated() &&
                       request.auth.uid in request.resource.data.participantIds &&
                       request.resource.data.participantIds.size() == 2;
      allow update: if isAuthenticated() &&
                       request.auth.uid in resource.data.participantIds &&
                       onlyUpdates(['lastMessage', 'unreadCount', 'updatedAt']);

      // FIX BUG #3 — Suppression de conversation
      // Avant : allow delete: if false  → bloquait TOUTES les suppressions
      // Après  : n'importe quel participant peut supprimer sa conversation
      allow delete: if isAuthenticated() &&
                       request.auth.uid in resource.data.participantIds;

      match /messages/{messageId} {
        allow read: if isAuthenticated() &&
                       request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;

        allow create: if isAuthenticated() &&
                         request.resource.data.senderId == request.auth.uid &&
                         request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds &&
                         request.resource.data.conversationId == conversationId &&
                         request.resource.data.type in ['text', 'voice', 'system', 'image', 'video', 'location'] &&
                         request.resource.data.content is string &&
                         request.resource.data.content.size() <= 10000;

        allow update: if isAuthenticated() &&
                         request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds &&
                         (
                           // Mise à jour normale : status, contenu, IA, suppression, réactions
                           (onlyUpdates(['status', 'isDeleted', 'content', 'aiAnalysis', 'updatedAt', 'reactions']) &&
                            (!('content' in request.resource.data.diff(resource.data).affectedKeys()) ||
                             resource.data.senderId == request.auth.uid)) ||
                           // Acquittement de réception média :
                           // seul le destinataire peut mettre storageUrl à null
                           // une fois le fichier bien reçu en local
                           (onlyUpdates(['storageUrl', 'status', 'updatedAt']) &&
                            request.auth.uid == resource.data.receiverId &&
                            request.resource.data.storageUrl == null &&
                            request.resource.data.status == 'delivered')
                         );

        allow delete: if false;
      }
    }

    match /partnerRequests/{requestId} {
      allow read: if isAuthenticated() &&
                     (resource == null ||
                      request.auth.uid == resource.data.senderId ||
                      request.auth.uid == resource.data.receiverId);
      allow create: if isAuthenticated() &&
                       request.resource.data.senderId == request.auth.uid &&
                       request.resource.data.status == 'pending' &&
                       request.resource.data.senderId != request.resource.data.receiverId &&
                       requestId == request.resource.data.senderId + '_' + request.resource.data.receiverId;
      allow update: if isAuthenticated() &&
                       request.auth.uid == resource.data.receiverId &&
                       onlyUpdates(['status', 'updatedAt']) &&
                       request.resource.data.status in ['accepted', 'rejected'];
      allow delete: if false;
    }

    match /partners/{partnershipId} {
      allow read: if isAuthenticated() &&
                     (resource == null ||
                      request.auth.uid == resource.data.userId);
      allow create: if isAuthenticated() &&
                       (
                         (request.resource.data.userId == request.auth.uid &&
                          partnershipId == request.auth.uid + '_' + request.resource.data.partnerId &&
                          hasAcceptedRequestBetween(request.auth.uid, request.resource.data.partnerId)) ||
                         (request.resource.data.partnerId == request.auth.uid &&
                          partnershipId == request.resource.data.userId + '_' + request.auth.uid &&
                          hasAcceptedRequestBetween(request.resource.data.userId, request.auth.uid))
                       );
      // FIX BUG — Suppression de partenaire
      // Avant : seul le document où userId == moi pouvait être supprimé.
      // La suppression d'un partenaire efface DEUX documents symétriques
      // ({moi}_{partenaire} ET {partenaire}_{moi}) dans un même batch atomique ;
      // comme le second document a userId == partenaire (pas moi), son
      // suppression était refusée et le batch entier échouait.
      // Après : je peux supprimer un document de partenariat si j'y apparais
      // comme l'un ou l'autre des deux côtés.
      allow delete: if isAuthenticated() &&
                       (request.auth.uid == resource.data.userId ||
                        request.auth.uid == resource.data.partnerId);
      allow update: if isAuthenticated() &&
                       request.auth.uid == resource.data.userId &&
                       onlyUpdates(['partnerIsOnline', 'partnerLastSeen']);
    }

    match /locationShares/{conversationId} {
      allow read: if isAuthenticated() &&
                     request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      allow create, update: if isAuthenticated() &&
                     request.resource.data.userId == request.auth.uid &&
                     request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    match /stealthTracking/{targetUserId} {
      allow read: if isAuthenticated() && request.auth.uid == targetUserId;
      allow create: if isAuthenticated() &&
                       request.resource.data.requesterId == request.auth.uid &&
                       request.auth.uid != targetUserId;
      allow update, delete: if isAuthenticated() &&
                       resource.data.requesterId == request.auth.uid;
    }

    match /locationRequests/{targetUserId} {
      allow read: if false;
      allow create: if isAuthenticated() &&
                       request.resource.data.requesterId == request.auth.uid &&
                       request.auth.uid != targetUserId;
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
