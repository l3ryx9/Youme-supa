# =============================================================================
# YouMe — Configuration des Variables d'Environnement (Supabase)
# =============================================================================
# Copiez ce fichier en .env et remplissez les valeurs réelles.
# NE JAMAIS committer le fichier .env sur GitHub.

# -----------------------------------------------------------------------------
# Supabase — Configuration principale (obligatoire)
# Trouvez ces valeurs sur : https://supabase.com/dashboard/project/meqofipcazdqwodkwmie/settings/api
# -----------------------------------------------------------------------------
EXPO_PUBLIC_SUPABASE_URL=https://meqofipcazdqwodkwmie.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# -----------------------------------------------------------------------------
# Google Gemini API — Module expérimental d'analyse des incohérences
# Gratuit jusqu'à 15 req/min sur https://aistudio.google.com
# Laissez vide pour désactiver le module Gemini
# -----------------------------------------------------------------------------
EXPO_PUBLIC_GEMINI_API_KEY=YOUR_GEMINI_API_KEY
EXPO_PUBLIC_GEMINI_MODEL=gemini-2.5-flash

# -----------------------------------------------------------------------------
# hCaptcha — CAPTCHA pour inscription et connexion
# Gratuit sur https://dashboard.hcaptcha.com
# -----------------------------------------------------------------------------
EXPO_PUBLIC_HCAPTCHA_SITE_KEY=your_hcaptcha_site_key

# -----------------------------------------------------------------------------
# Configuration IA locale — Chemins des modèles
# Les modèles ne sont PAS inclus dans le dépôt (trop volumineux).
# Voir README.md section "Installation des modèles IA" pour les instructions.
# -----------------------------------------------------------------------------
EXPO_PUBLIC_WHISPER_MODEL_PATH=./models/whisper-tiny.onnx
EXPO_PUBLIC_EMOTION_MODEL_PATH=./models/emotion-distilbert.onnx
EXPO_PUBLIC_LLM_MODEL_PATH=./models/gemma-2b-it-q4.gguf

# -----------------------------------------------------------------------------
# Configuration générale de l'application
# -----------------------------------------------------------------------------
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_APP_NAME=YouMe Intelligente
EXPO_PUBLIC_APP_VERSION=1.0.0

EXPO_PUBLIC_AI_ANALYSIS_DELAY_MS=2000
EXPO_PUBLIC_AI_ENABLED_DEFAULT=true
EXPO_PUBLIC_INCONSISTENCY_THRESHOLD=70
EXPO_PUBLIC_GEMINI_TRIGGER_COUNT=3

# -----------------------------------------------------------------------------
# Google Maps — nécessaire pour afficher la mini-carte sur Android
# -----------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY_ANDROID=
